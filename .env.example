# Az Notification Hub — Edge Runtime
# Copy to .env.local for local development or configure as Cloudflare Worker secrets.

# Public ingestion fallback security.
# Production should use notification_sources.bearer_token_hash per connected system.
INGEST_TOKEN=change-me-long-random-token
ALLOW_PUBLIC_INGEST_WITHOUT_TOKEN=false

# Supabase Postgres/PostgREST persistence and source registry.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
SUPABASE_ANON_KEY=replace-with-anon-key
REQUIRE_SUPABASE=false

# Optional HMAC secrets. The DB stores hmac_secret_env_name, not the secret itself.
# Example: set notification_sources.hmac_secret_env_name = 'HMAC_SECRET_UBERFIX'.
HMAC_SECRET_ALAZAB_MAIN=
HMAC_SECRET_UBERFIX=
HMAC_SECRET_ERP=
HMAC_SECRET_AI=
HMAC_SECRET_PHOTOS=
HMAC_SECRET_AGENT=
HMAC_SECRET_PROUDCTE=

# Optional Inngest event API bridge for retries/delays.
# This repository currently uses the HTTP Events API adapter to stay Edge-safe
# without adding package dependencies before the lockfile is regenerated.
INNGEST_EVENT_KEY=
INNGEST_EVENT_URL=https://inn.gs/e/

# Optional public app metadata.
VITE_APP_DOMAIN=https://notify.alazab.com
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=replace-with-anon-key

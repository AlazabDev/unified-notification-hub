# Az Notification Hub — Edge Runtime
# Copy to .env.local for local development or configure as Cloudflare Worker secrets.

# Public ingestion security. Required unless ALLOW_PUBLIC_INGEST_WITHOUT_TOKEN=true.
INGEST_TOKEN=change-me-long-random-token
ALLOW_PUBLIC_INGEST_WITHOUT_TOKEN=false

# Supabase Postgres/PostgREST persistence.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
SUPABASE_ANON_KEY=replace-with-anon-key
REQUIRE_SUPABASE=false

# Optional Inngest event API bridge for retries/delays.
# This repository currently uses the HTTP Events API adapter to stay Edge-safe
# without adding package dependencies before the lockfile is regenerated.
INNGEST_EVENT_KEY=
INNGEST_EVENT_URL=https://inn.gs/e/

# Optional public app metadata.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=replace-with-anon-key
